# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual envs
.venv/
venv/
env/

# saddle runtime state (SQLite store defaults to ~/.saddle, but keep the
# repo clean if SADDLE_HOME ever points inside the tree)
*.db
*.db-wal
*.db-shm
.saddle/

# Per-tenant/project policy is written at runtime by `saddle directive`
# (policy.promote_directive) with a sibling lock file — machine-local
# state, not source. The shared default config/llm_policy.json IS tracked.
config/tenants/**/policy.json
config/tenants/**/policy.json.lock

# Secrets — API keys live in a SHARED file referenced by policy.keys_from
# and are NEVER committed. Ignore any local key file dropped into the repo.
config/llm_config.json
config/tenants/**/keys*.json
*.env
.env

# Editor / OS
.DS_Store
*.swp

# Claude local-only settings (project-level settings.json IS tracked)
.claude/settings.local.json

# Runtime lock files
*.lock
